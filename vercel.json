{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "images": {
    "sizes": [320, 480, 640, 750, 828, 1080, 1280],
    "qualities": [75],
    "formats": ["image/webp", "image/avif"],
    "minimumCacheTTL": 3600,
    "localPatterns": [
      {
        "pathname": "^/gallery/.*$"
      }
    ],
    "remotePatterns": [
      {
        "protocol": "https",
        "hostname": "^.*\\.public\\.blob\\.vercel-storage\\.com$",
        "port": "",
        "pathname": "^/gallery/.*$"
      }
    ]
  }
}
